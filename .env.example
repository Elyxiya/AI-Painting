# ─────────────────────────────────────────────────────────────────────
# AI-Painting v2 — environment variables
# Copy to `.env.local` and fill in your own values.
# ─────────────────────────────────────────────────────────────────────

# DeepSeek API key (get from https://platform.deepseek.com)
# When empty, the app runs in rule-only mode (regex command parser).
VITE_DEEPSEEK_API_KEY=

# DeepSeek API base URL (optional, defaults to https://api.deepseek.com)
VITE_LLM_BASE_URL=https://api.deepseek.com

# LLM model name (optional, defaults to deepseek-chat)
VITE_LLM_MODEL=deepseek-chat

# Server-side Whisper fallback URL (optional, for when local WASM is unavailable)
VITE_WHISPER_API_URL=
